# ── rsky-pds local development environment ───────────────────────────────────
# Copy this file to docker/.env and fill in the values.
# Run scripts/setup-local.sh to generate the secp256k1 keys.
#
# DATABASE_URL and AWS_ENDPOINT are overridden by docker-compose.yml to point
# at the compose-internal service names; the values here are used when running
# the binary directly outside Docker.

# ── Core service ─────────────────────────────────────────────────────────────
PDS_PORT=2583
PDS_HOSTNAME=localhost

# did:web:{hostname} is the default — override if you expose the PDS publicly.
PDS_SERVICE_DID=did:web:localhost

# Disable invite requirement for local testing
PDS_INVITE_REQUIRED=false

# Enable dev-mode relaxations (e.g. looser CORS)
PDS_DEV_MODE=true

# ── Crypto keys (generate with scripts/setup-local.sh) ───────────────────────
PDS_JWT_KEY_K256_PRIVATE_KEY_HEX=
PDS_PLC_ROTATION_KEY_K256_PRIVATE_KEY_HEX=
PDS_REPO_SIGNING_KEY_K256_PRIVATE_KEY_HEX=

# ── Admin ────────────────────────────────────────────────────────────────────
PDS_ADMIN_PASS=hunter2

# ── Database ─────────────────────────────────────────────────────────────────
# Overridden by docker-compose.yml (points at the postgres service).
DATABASE_URL=postgresql://rsky:rsky@localhost:5432/rsky_pds

# ── Object storage (MinIO) ───────────────────────────────────────────────────
# Overridden by docker-compose.yml (points at the minio service).
AWS_ENDPOINT=http://localhost:9000
AWS_ENDPOINT_BUCKET=rsky-pds-blobs
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1

# ── Identity ─────────────────────────────────────────────────────────────────
# Use the public PLC directory. Override with a local mock if you need
# fully offline operation.
PDS_DID_PLC_URL=https://plc.directory

# Handles for this PDS will be accepted under these domains.
# Defaults to ".test" when hostname is localhost.
# PDS_SERVICE_HANDLE_DOMAINS=.test

# ── AppView (optional — skip for smoke testing) ───────────────────────────────
# PDS_BSKY_APP_VIEW_URL=https://api.bsky.app
# PDS_BSKY_APP_VIEW_DID=did:web:api.bsky.app

# ── Email (optional — not required for atproto-smoke) ────────────────────────
# PDS_EMAIL_FROM_NAME=rsky-pds-dev
# PDS_EMAIL_FROM_ADDRESS=dev@localhost
# PDS_MODERATION_EMAIL_FROM_NAME=rsky-pds-mod
# PDS_MODERATION_EMAIL_FROM_ADDRESS=mod@localhost

# ── Subscription tuning ───────────────────────────────────────────────────────
PDS_MAX_SUBSCRIPTION_BUFFER=500
# PDS_REPO_BACKFILL_LIMIT_MS=86400000
